<ui:FluentWindow x:Class="FleetAutomate.View.Dialog.SetVariableDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        mc:Ignorable="d"
        Title="Create Variable"
        Height="500"
        Width="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize" MinWidth="400" MinHeight="250"
        WindowStyle="None">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title Bar -->
        <ui:TitleBar Grid.Row="0"
                    Title="Create Variable"
                    Icon="{ui:SymbolIcon DocumentAdd20}"/>

        <!-- Content -->
        <StackPanel Grid.Row="1" Margin="20" VerticalAlignment="Top">
            <!-- Variable Name -->
            <TextBlock Text="Name" FontWeight="Bold" FontSize="12" Margin="0,0,0,5"/>
            <TextBox Name="VariableNameTextBox"
                    Padding="8"
                    Margin="0,0,0,15"
                    Height="32"
                    ToolTip="Enter a valid variable name (alphanumeric and underscore)"/>

            <!-- Variable Type -->
            <TextBlock Name="VariableTypeLabelTextBlock" Text="Type" FontWeight="Bold" FontSize="12" Margin="0,0,0,5"/>
            <ComboBox Name="VariableTypeComboBox"
                     Padding="8,4"
                     Margin="0,0,0,15"
                     MinHeight="36"
                     SelectedIndex="0">
                <ComboBoxItem VerticalContentAlignment="Center">Integer (int)</ComboBoxItem>
                <ComboBoxItem VerticalContentAlignment="Center">Decimal (double)</ComboBoxItem>
                <ComboBoxItem VerticalContentAlignment="Center">Text</ComboBoxItem>
                <ComboBoxItem VerticalContentAlignment="Center">Boolean</ComboBoxItem>
            </ComboBox>

            <!-- Value Mode -->
            <TextBlock Text="Value Mode" FontWeight="Bold" FontSize="12" Margin="0,0,0,5"/>
            <ComboBox Name="ValueModeComboBox"
                     Padding="8,4"
                     Margin="0,0,0,15"
                     MinHeight="36"
                     SelectedIndex="0">
                <ComboBoxItem VerticalContentAlignment="Center">Literal</ComboBoxItem>
                <ComboBoxItem VerticalContentAlignment="Center">Expression</ComboBoxItem>
            </ComboBox>

            <!-- Expression Templates -->
            <StackPanel Name="ExpressionTemplatePanel" Margin="0,0,0,15" Visibility="Collapsed">
                <TextBlock Text="Insert Template" FontWeight="Bold" FontSize="12" Margin="0,0,0,5"/>
                <DockPanel>
                    <ui:Button Name="InsertTemplateButton"
                               DockPanel.Dock="Right"
                               Content="Insert"
                               Margin="8,0,0,0"
                               Padding="16,0"
                               Click="InsertTemplateButton_Click"/>
                    <ComboBox Name="ExpressionTemplateComboBox"
                              Padding="8,4"
                              MinHeight="36"
                              DisplayMemberPath="DisplayName"
                              SelectedValuePath="Id"/>
                </DockPanel>
            </StackPanel>

            <!-- Variable Value -->
            <TextBlock Name="ValueLabelTextBlock" Text="Value" FontWeight="Bold" FontSize="12" Margin="0,0,0,5"/>
            <TextBox Name="VariableValueTextBox"
                    Padding="8"
                    Margin="0,0,0,15"
                    MinHeight="32"
                    ToolTip="Enter the initial value for the variable"/>

            <!-- Hint Text -->
            <TextBlock Name="HintTextBlock"
                      Text="Enter an integer value"
                      FontSize="10"
                      Foreground="Gray"
                      Margin="0,0,0,15"/>
        </StackPanel>

        <!-- Buttons -->
        <Border Grid.Row="2" Background="#F5F5F5" Padding="20" BorderBrush="LightGray" BorderThickness="0,1">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <ui:Button Name="OkButton"
                          Content="Create"
                          Appearance="Primary"
                          Click="OkButton_Click"
                          Padding="20,0"
                          Margin="0,0,10,0"/>
                <ui:Button Name="CancelButton"
                          Content="Cancel"
                          Click="CancelButton_Click"
                          Padding="20,0"
                          IsCancel="True"/>
            </StackPanel>
        </Border>
    </Grid>
</ui:FluentWindow>



