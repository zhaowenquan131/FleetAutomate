<ui:FluentWindow x:Class="FleetAutomate.View.Dialog.ClickElementDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:controls="clr-namespace:FleetAutomate.View.Controls"
        mc:Ignorable="d"
        Title="Click Element"
        Height="550"
        Width="550"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize" MinWidth="400" MinHeight="250"
        WindowStyle="None">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title Bar -->
        <ui:TitleBar Grid.Row="0"
                    Title="Click Element"
                    Icon="{ui:SymbolIcon CursorClick20}"/>

        <!-- Content -->
        <ScrollViewer Grid.Row="1">
            <StackPanel Margin="20" VerticalAlignment="Top">
                <!-- Identifier Type -->
                <TextBlock Text="Identifier Type" FontWeight="Bold" FontSize="12" Margin="0,0,0,5"/>
                <ComboBox Name="IdentifierTypeComboBox"
                         Padding="8,4"
                         Margin="0,0,0,15"
                         MinHeight="36"
                         SelectedIndex="0">
                    <ComboBoxItem VerticalContentAlignment="Center">XPath</ComboBoxItem>
                    <ComboBoxItem VerticalContentAlignment="Center">AutomationId</ComboBoxItem>
                    <ComboBoxItem VerticalContentAlignment="Center">Name</ComboBoxItem>
                    <ComboBoxItem VerticalContentAlignment="Center">ClassName</ComboBoxItem>
                </ComboBox>

                <!-- Search Scope -->
                <TextBlock Text="Search Scope" FontWeight="Bold" FontSize="12" Margin="0,0,0,5"/>
                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <ComboBox Name="SearchScopeComboBox"
                             Grid.Column="0"
                             Padding="8,4"
                             MinHeight="36"
                             IsEditable="False"
                             ToolTip="Select a previously captured element as search root (faster search)">
                        <ComboBoxItem IsSelected="True" VerticalContentAlignment="Center">(Desktop - Full Search)</ComboBoxItem>
                    </ComboBox>
                    <CheckBox Name="AddSearchScopeToGlobalDictionary"
                             Grid.Column="1"
                             Content="Add to Dict"
                             VerticalAlignment="Center"
                             Margin="10,0,0,0"
                             ToolTip="Add the search scope element to the global dictionary"/>
                </Grid>

                <!-- Element Identifier -->
                <TextBlock Text="Element Identifier" FontWeight="Bold" FontSize="12" Margin="0,0,0,5"/>
                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <controls:XPathInput x:Name="ElementIdentifierInput"
                                        Grid.Column="0"
                                        ToolTip="Enter the element identifier or click 'Capture Element' to select from UI"/>
                    <CheckBox Name="AddElementToGlobalDictionary"
                             Grid.Column="1"
                             Content="Add to Dict"
                             VerticalAlignment="Center"
                             Margin="10,0,0,0"
                             ToolTip="Add this element to the global dictionary for use as search scope in subsequent actions"/>
                </Grid>

                <!-- Double Click Checkbox -->
                <CheckBox Name="DoubleClickCheckBox"
                         Content="Double Click"
                         Margin="0,0,0,10"
                         ToolTip="Check to perform a double-click instead of single-click"/>

                <!-- Use Invoke Checkbox -->
                <CheckBox Name="UseInvokeCheckBox"
                         Content="Use Invoke Pattern"
                         Margin="0,0,0,15"
                         ToolTip="Use Invoke pattern instead of mouse click (useful when element is behind another element)"/>

                <!-- Retry Times -->
                <TextBlock Text="Retry Times" FontWeight="Bold" FontSize="12" Margin="0,0,0,5"/>
                <TextBox Name="RetryTimesTextBox"
                        Padding="8"
                        Margin="0,0,0,5"
                        Height="32"
                        Text="3"
                        ToolTip="Number of times to retry if action fails (0 = no retry)"/>
                <TextBlock Text="Number of retry attempts if the action fails (0 = no retry, 1 attempt only)"
                          FontSize="10"
                          Foreground="Gray"
                          TextWrapping="Wrap"
                          Margin="0,0,0,15"/>

                <!-- Retry Delay -->
                <TextBlock Text="Retry Delay (ms)" FontWeight="Bold" FontSize="12" Margin="0,0,0,5"/>
                <TextBox Name="RetryDelayTextBox"
                        Padding="8"
                        Margin="0,0,0,15"
                        Height="32"
                        Text="500"
                        ToolTip="Delay in milliseconds between retry attempts"/>

                <!-- Hint Text -->
                <TextBlock Text="XPath Example: //Button[@Name='Login']"
                          FontSize="10"
                          Foreground="Gray"
                          TextWrapping="Wrap"
                          Margin="0,0,0,5"/>
                <TextBlock Text="AutomationId Example: btnLogin"
                          FontSize="10"
                          Foreground="Gray"
                          TextWrapping="Wrap"
                          Margin="0,0,0,10"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Buttons -->
        <Border Grid.Row="2" Background="#F5F5F5" Padding="20" BorderBrush="LightGray" BorderThickness="0,1">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <ui:Button Name="OkButton"
                          Content="Create"
                          Appearance="Primary"
                          Click="OkButton_Click"
                          Padding="20,0"
                          Margin="0,0,10,0"/>
                <ui:Button Name="CancelButton"
                          Content="Cancel"
                          Click="CancelButton_Click"
                          Padding="20,0"
                          IsCancel="True"/>
            </StackPanel>
        </Border>
    </Grid>
</ui:FluentWindow>



