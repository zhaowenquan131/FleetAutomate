<ui:FluentWindow x:Class="FleetAutomate.View.Dialog.WaitDurationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        mc:Ignorable="d"
        Title="Wait"
        Height="260"
        Width="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0"
                     Title="Wait"
                     Icon="{ui:SymbolIcon Clock20}"/>

        <StackPanel Grid.Row="1" Margin="20">
            <TextBlock Text="Duration" FontWeight="Bold" FontSize="12" Margin="0,0,0,5"/>
            <TextBox Name="DurationTextBox"
                     MinHeight="36"
                     Padding="8"
                     Text="1"
                     Margin="0,0,0,15"
                     ToolTip="Enter a positive whole number."/>

            <TextBlock Text="Unit" FontWeight="Bold" FontSize="12" Margin="0,0,0,5"/>
            <ComboBox Name="UnitComboBox"
                      MinHeight="36"
                      SelectedIndex="0">
                <ComboBoxItem Content="Seconds" VerticalContentAlignment="Center"/>
                <ComboBoxItem Content="Minutes" VerticalContentAlignment="Center"/>
            </ComboBox>

            <TextBlock Text="The wait runs asynchronously, so FleetAutomate remains responsive."
                       FontSize="10"
                       Foreground="Gray"
                       TextWrapping="Wrap"
                       Margin="0,15,0,0"/>
        </StackPanel>

        <Border Grid.Row="2" Background="#F5F5F5" Padding="20" BorderBrush="LightGray" BorderThickness="0,1">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <ui:Button Name="OkButton"
                           Content="Create"
                           Appearance="Primary"
                           Click="OkButton_Click"
                           Padding="20,0"
                           Margin="0,0,10,0"/>
                <ui:Button Content="Cancel"
                           Click="CancelButton_Click"
                           Padding="20,0"
                           IsCancel="True"/>
            </StackPanel>
        </Border>
    </Grid>
</ui:FluentWindow>
